# LiveWalk mobile runtime config
# app.config.ts reads these values into Expo extra.
# Change the API URL before exporting/building to point the app at a different backend.
EXPO_PUBLIC_API_BASE_URL=https://rendezvous-livewalk-api.webpeter.com

# Optional CI/build alias. If both are set, LIVEWALK_API_BASE_URL wins.
# LIVEWALK_API_BASE_URL=https://rendezvous-livewalk-api.webpeter.com

# Public Mapbox runtime tokens. Provide both; the web runtime reads the web token and native reads the mobile token.
MAPBOX_TOKEN_WEB=
MAPBOX_TOKEN_MOBILE=
