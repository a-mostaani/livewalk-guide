# LiveWalk mobile runtime config
# app.config.js reads these values into Expo extra.
# Change the API URL before exporting/building to point the app at a different backend.
EXPO_PUBLIC_API_BASE_URL=https://rendezvous-livewalk-api.webpeter.com

# Optional CI/build alias. If both are set, LIVEWALK_API_BASE_URL wins.
# LIVEWALK_API_BASE_URL=https://rendezvous-livewalk-api.webpeter.com

# Public LiveKit signaling endpoint. app.config.js exposes it as extra.livekitWsUrl
# for the client runtime. It identifies the LiveKit server but does not authorize a session.
# Keep all server credentials and signing material out of this app.
LIVEKIT_WS_URL=wss://your-livekit-project.livekit.cloud

# Public Mapbox runtime tokens. Provide both; the web runtime reads the web token and native reads the mobile token.
# For EAS, set MAPBOX_TOKEN_MOBILE in each named build environment
# (development, preview, production). app.config.js copies it to
# Expo extra.mapboxTokenMobile during build configuration; never commit a real token.
MAPBOX_TOKEN_WEB=
MAPBOX_TOKEN_MOBILE=
